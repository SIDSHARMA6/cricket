{
  "kind": "collectionType",
  "collectionName": "direct_messages",
  "info": {
    "singularName": "direct-message",
    "pluralName": "direct-messages",
    "displayName": "direct-message"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "sender": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "receiver": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "message": {
      "type": "richtext",
      "required": true
    },
    "message_type": {
      "type": "enumeration",
      "enum": [
        "text",
        "image",
        "video",
        "voice"
      ],
      "default": "text"
    },
    "attachments": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "videos",
        "files"
      ]
    },
    "conversation_id": {
      "type": "string",
      "required": false
    },
    "read": {
      "type": "boolean",
      "default": false
    },
    "delivered": {
      "type": "boolean",
      "default": false
    },
    "deleted_by_sender": {
      "type": "boolean",
      "default": false
    },
    "deleted_by_receiver": {
      "type": "boolean",
      "default": false
    }
  }
}
