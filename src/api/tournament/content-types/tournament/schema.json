{
  "kind": "collectionType",
  "collectionName": "tournaments",
  "info": {
    "singularName": "tournament",
    "pluralName": "tournaments",
    "displayName": "tournament"
  },
  "options": {
    "draftAndPublish": false,
    "populateCreatorFields": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "banner": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "start_date": {
      "type": "date",
      "required": true
    },
    "end_date": {
      "type": "date"
    },
    "organizer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "teams": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::team.team"
    },
    "matches": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::match.match",
      "mappedBy": "tournament"
    },
    "format": {
      "type": "enumeration",
      "enum": [
        "knockout",
        "round-robin",
        "league"
      ],
      "default": "knockout"
    },
    "registration_deadline": {
      "type": "date"
    },
    "entry_fee": {
      "type": "decimal",
      "default": 0
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "venue": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "ongoing",
        "completed"
      ],
      "default": "upcoming"
    },
    "winner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team"
    }
  }
}
