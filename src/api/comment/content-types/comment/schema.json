{
  "kind": "collectionType",
  "collectionName": "comments",
  "info": {
    "singularName": "comment",
    "pluralName": "comments",
    "displayName": "Comment"
  },
  "options": {
    "draftAndPublish": false,
    "populateCreatorFields": false
  },
  "pluginOptions": {},
  "attributes": {
    "text": {
      "type": "text",
      "required": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "post": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::post.post"
    },
    "story": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::story.story"
    },
    "liked_by": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "likes_count": {
      "type": "integer",
      "default": 0
    },
    "replies_count": {
      "type": "integer",
      "default": 0
    },
    "parent_comment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::comment.comment"
    }
  }
}